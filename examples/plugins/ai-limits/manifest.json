        "title": "AI Limits",
        "opens": "usage.panel"
      }
    ],
    "statusBar": [
      {
        "id": "usage.sb.claude.name",
        "align": "left",
        "priority": 70
      },
      {
        "id": "usage.sb.claude.5h",
        "align": "left",
        "priority": 71
      },
      {
        "id": "usage.sb.claude.week",
        "align": "left",
        "priority": 72
      },
      {
        "id": "usage.sb.claude.today",
        "align": "left",
        "priority": 73
      },
      {
        "id": "usage.sb.claude.tok",
        "align": "left",
        "priority": 74
      },
      {
        "id": "usage.sb.claude.reset",
        "align": "left",
        "priority": 75
      },
      {
        "id": "usage.sb.claude.wkReset",
        "align": "left",
        "priority": 76
      },
      {
        "id": "usage.sb.codex.name",
        "align": "left",
        "priority": 80
      },
      {
        "id": "usage.sb.codex.today",
        "align": "left",
        "priority": 81
      },
      {
        "id": "usage.sb.codex.tok",
        "align": "left",
        "priority": 82
      }
    ],
    "panels": [
      {
        "id": "usage.panel",
        "location": "right",
        "title": "AI Limits",
        "render": "iframe",
        "entry": "panel.html"
      }
    ],
    "commands": [
      {
        "id": "usage.refresh",
        "title": "Usage: обновить"
