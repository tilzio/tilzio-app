{
  "id": "dev.term.git",
  "name": "Git",
  "version": "1.0.0",
  "engine": "tilzio@1",
  "entry": "main.js",
  "permissions": ["exec", "state:read", "terminal:write"],
  "exec": ["git"],
  "contributes": {
    "activityBar": [{ "id": "git.btn", "icon": "🌿", "title": "Git", "opens": "git.panel" }],
    "statusBar":   [{ "id": "git.branch", "align": "left", "priority": 90 }],
    "panels":      [{ "id": "git.panel", "location": "bottom", "title": "Git", "render": "widgets" }],
    "commands":    [
      { "id": "git.refresh", "title": "Git: refresh" },
      { "id": "git.pull", "title": "Git: pull" },
      { "id": "git.pasteStatus", "title": "Git: paste «git status» (without Enter)" },
      { "id": "git.probeDenied", "title": "Git: allow-list probe (ls)" }
    ]
  }
}
